# Environment Variables
NODE_ENV=development
PORT=3000

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Google OAuth (Get from Google Cloud Console)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# Apple OAuth (Get from Apple Developer)
APPLE_TEAM_ID=YOUR_APPLE_TEAM_ID
APPLE_KEY_ID=YOUR_APPLE_KEY_ID
APPLE_BUNDLE_ID=com.freemoviewatchers.app

# Database (Optional - for user storage)
DB_URI=mongodb://localhost:27017/freemoviewatchers

# Frontend URL
FRONTEND_URL=http://localhost:3000
FRONTEND_PROD_URL=https://arshanehanluxpro.github.io/FreeMovieWatchers.inc
